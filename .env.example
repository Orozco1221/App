# Copia este fichero como ".env" y rellena tus valores reales.
# El .env NUNCA debe subirse a GitHub (ya está en .gitignore).

# Gemini API — Google
REACT_APP_GEMINI_KEY=tu_gemini_api_key_aqui

# GitHub — para operaciones con git (opcional)
GITHUB_TOKEN=tu_github_token_aqui

# Supabase — base de datos y almacenamiento
REACT_APP_SUPABASE_URL=tu_supabase_url_aqui
REACT_APP_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui
